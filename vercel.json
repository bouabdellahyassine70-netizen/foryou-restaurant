{
  "version": 2,
  "buildCommand": "cd backend && npm install && npm run vercel-build",
  "installCommand": "cd backend && npm install",
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "includeFiles": [
          "backend/dist/**",
          "backend/prisma/**",
          "backend/node_modules/.prisma/**",
          "backend/node_modules/@prisma/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/api/index.js"
    }
  ]
}
