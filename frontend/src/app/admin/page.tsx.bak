'use client';

import { useState, useEffect } from 'react';
import { useQuery } from '@tanstack/react-query';
import { api } from '@/lib/api';
import { useAuthStore } from '@/lib/store';
import { useRouter } from 'next/navigation';
import Link from 'next/link';

export default function AdminPage() {
  const [activeTab, setActiveTab] = useState<'orders' | 'menu' | 'users' | 'analytics'>('orders');
  const { user, logout } = useAuthStore();
  const router = useRouter();

  useEffect(() => {
    // Redirect to login if not authenticated
    const token = localStorage.getItem('token');
    if (!token || !user) {
      router.push('/admin/login');
    }
  }, [user, router]);

  if (!user) {
    return <div>Loading...</div>;
  }

  return (
    <div className="min-h-screen bg-gray-50">
      <header className="bg-white shadow-sm">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
          <div className="flex justify-between items-center">
            <h1 className="text-2xl font-bold">Admin Dashboard</h1>
            <div className="flex gap-4 items-center">
              <span className="text-sm text-gray-600">Welcome, {user.email}</span>
              <Link href="/" className="text-gray-600 hover:text-gray-900 text-sm">
                Menu
              </Link>
              <button
                onClick={() => {
                  logout();
                  router.push('/admin/login');
                }}
                className="text-red-600 hover:text-red-700 text-sm"
              >
                Logout
              </button>
            </div>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div className="bg-white rounded-lg shadow">
          <div className="border-b">
            <nav className="flex">
              <button
                onClick={() => setActiveTab('orders')}
                className={`px-6 py-3 font-medium ${
                  activeTab === 'orders'
                    ? 'border-b-2 border-primary-600 text-primary-600'
                    : 'text-gray-500 hover:text-gray-700'
                }`}
              >
                Orders
              </button>
              <button
                onClick={() => setActiveTab('menu')}
                className={`px-6 py-3 font-medium ${
                  activeTab === 'menu'
                    ? 'border-b-2 border-primary-600 text-primary-600'
                    : 'text-gray-500 hover:text-gray-700'
                }`}
              >
                Menu
              </button>
              <button
                onClick={() => setActiveTab('users')}
                className={`px-6 py-3 font-medium ${
                  activeTab === 'users'
                    ? 'border-b-2 border-primary-600 text-primary-600'
                    : 'text-gray-500 hover:text-gray-700'
                }`}
              >
                Users
              </button>
              <button
                onClick={() => setActiveTab('analytics')}
                className={`px-6 py-3 font-medium ${
                  activeTab === 'analytics'
                    ? 'border-b-2 border-primary-600 text-primary-600'
                    : 'text-gray-500 hover:text-gray-700'
                }`}
              >
                Analytics
              </button>
            </nav>
          </div>

          <div className="p-6">
            {activeTab === 'orders' && <OrdersTab />}
            {activeTab === 'menu' && <MenuTab />}
            {activeTab === 'users' && <UsersTab />}
            {activeTab === 'analytics' && <AnalyticsTab />}
          </div>
        </div>
      </main>
    </div>
  );
}

function OrdersTab() {
  const { data: orders, refetch } = useQuery({
    queryKey: ['admin-orders'],
    queryFn: async () => {
      const res = await api.get('/orders');
      return res.data;
    },
    refetchInterval: 5000,
  });

  const updateStatus = async (orderId: string, status: string) => {
    try {
      await api.patch(`/orders/${orderId}/status`, { status });
      refetch();
      // Show success feedback
      alert(`Order status updated to ${status}`);
    } catch (error: any) {
      const errorMessage = error.response?.data?.message || error.message || 'Failed to update status';
      console.error('Failed to update status:', error);
      alert(`Error: ${errorMessage}`);
    }
  };

  if (!orders) return <div>Loading...</div>;

  if (orders.length === 0) {
    return (
      <div>
        <h2 className="text-xl font-bold mb-4">All Orders</h2>
        <p className="text-gray-500">No orders yet. Orders will appear here once customers place them.</p>
      </div>
    );
  }

  return (
    <div>
      <h2 className="text-xl font-bold mb-4">All Orders</h2>
      <div className="space-y-4">
        {orders.map((order: any) => (
          <div key={order.id} className="border rounded p-4">
            <div className="flex justify-between items-start mb-2">
              <div>
                <p className="font-semibold">Order #{order.orderNumber}</p>
                <p className="text-sm text-gray-600">
                  {new Date(order.createdAt).toLocaleString()}
                </p>
              </div>
              <span
                className={`px-3 py-1 rounded text-sm font-medium ${
                  order.status === 'COMPLETED'
                    ? 'bg-green-100 text-green-800'
                    : order.status === 'CANCELLED'
                    ? 'bg-red-100 text-red-800'
                    : 'bg-yellow-100 text-yellow-800'
                }`}
              >
                {order.status}
              </span>
            </div>
            <div className="mb-2">
              <p className="text-sm">Type: {order.type}</p>
              <p className="text-sm">Total: ${Number(order.total).toFixed(2)}</p>
            </div>
            <div className="flex gap-2 mt-4 flex-wrap">
              {order.status === 'CREATED' && (
                <button
                  onClick={() => updateStatus(order.id, 'CONFIRMED')}
                  className="px-4 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700"
                >
                  Confirm Order
                </button>
              )}
              {order.status === 'CONFIRMED' && (
                <button
                  onClick={() => updateStatus(order.id, 'ACCEPTED')}
                  className="px-4 py-2 bg-primary-600 text-white rounded text-sm hover:bg-primary-700"
                >
                  Accept Order
                </button>
              )}
              {order.status === 'ACCEPTED' && (
                <button
                  onClick={() => updateStatus(order.id, 'PREPARING')}
                  className="px-4 py-2 bg-orange-600 text-white rounded text-sm hover:bg-orange-700"
                >
                  Start Preparing
                </button>
              )}
              {order.status === 'PREPARING' && (
                <button
                  onClick={() => updateStatus(order.id, 'READY')}
                  className="px-4 py-2 bg-yellow-600 text-white rounded text-sm hover:bg-yellow-700"
                >
                  Mark Ready
                </button>
              )}
              {order.status === 'READY' && (
                <button
                  onClick={() => updateStatus(order.id, 'SERVED')}
                  className="px-4 py-2 bg-green-600 text-white rounded text-sm hover:bg-green-700"
                >
                  Mark Served
                </button>
              )}
              {order.status === 'SERVED' && (
                <button
                  onClick={() => updateStatus(order.id, 'COMPLETED')}
                  className="px-4 py-2 bg-purple-600 text-white rounded text-sm hover:bg-purple-700"
                >
                  Complete Order
                </button>
              )}
              {order.status !== 'COMPLETED' && order.status !== 'CANCELLED' && (
                <button
                  onClick={() => updateStatus(order.id, 'CANCELLED')}
                  className="px-4 py-2 bg-red-600 text-white rounded text-sm hover:bg-red-700"
                >
                  Cancel Order
                </button>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

function MenuTab() {
  return <div>Menu management coming soon...</div>;
}

function UsersTab() {
  return <div>User management coming soon...</div>;
}

function AnalyticsTab() {
  const { data: analytics, isLoading } = useQuery({
    queryKey: ['admin-analytics'],
    queryFn: async () => {
      const res = await api.get('/orders/analytics');
      return res.data;
    },
    refetchInterval: 60000, // Refetch every minute
  });

  if (isLoading) return <div>Loading analytics...</div>;
  if (!analytics) return <div>No data available</div>;

  return (
    <div className="space-y-6">
      <h2 className="text-xl font-bold mb-4">Analytics Dashboard</h2>
      
      {/* Daily Sales */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div className="bg-white border rounded-lg p-6">
          <h3 className="text-sm font-medium text-gray-600 mb-2">Today's Sales</h3>
          <p className="text-3xl font-bold text-gray-900">${Number(analytics.todaySales || 0).toFixed(2)}</p>
          <p className="text-sm text-gray-500 mt-1">{analytics.todayOrders || 0} orders</p>
        </div>
        <div className="bg-white border rounded-lg p-6">
          <h3 className="text-sm font-medium text-gray-600 mb-2">This Week</h3>
          <p className="text-3xl font-bold text-gray-900">${Number(analytics.weekSales || 0).toFixed(2)}</p>
          <p className="text-sm text-gray-500 mt-1">{analytics.weekOrders || 0} orders</p>
        </div>
        <div className="bg-white border rounded-lg p-6">
          <h3 className="text-sm font-medium text-gray-600 mb-2">Average Order</h3>
          <p className="text-3xl font-bold text-gray-900">${Number(analytics.avgOrder || 0).toFixed(2)}</p>
        </div>
      </div>

      {/* Popular Items */}
      <div className="bg-white border rounded-lg p-6">
        <h3 className="text-lg font-semibold mb-4">Popular Items</h3>
        <div className="space-y-2">
          {analytics.popularItems?.slice(0, 10).map((item: any, index: number) => (
            <div key={item.id} className="flex justify-between items-center border-b pb-2">
              <span className="font-medium">
                {index + 1}. {item.name}
              </span>
              <span className="text-gray-600">{item.count} orders</span>
            </div>
          ))}
        </div>
      </div>

      {/* Rush Hours */}
      <div className="bg-white border rounded-lg p-6">
        <h3 className="text-lg font-semibold mb-4">Peak Hours</h3>
        <div className="space-y-2">
          {analytics.rushHours?.map((hour: any) => (
            <div key={hour.hour} className="flex justify-between items-center border-b pb-2">
              <span className="font-medium">{hour.hour}:00</span>
              <span className="text-gray-600">{hour.count} orders</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
